<Window x:Class="_.GameSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Mode Settings"
        Height="380"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="OK"
                    Width="80"
                    Height="25"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel"
                    Width="80"
                    Height="25"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="CCD group applied to detected games:"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap"/>
        <ComboBox DockPanel.Dock="Top"
                  ItemsSource="{Binding AvailableCcds}"
                  SelectedItem="{Binding SelectedCcd}"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,14"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="Always-game process names (one per line). Fullscreen apps are detected automatically; add names here for windowed games:"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap"/>
        <TextBox Text="{Binding GameNamesText, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"/>
    </DockPanel>
</Window>
